# LLM investigator provider. Default `mock` runs fully offline with no API key.
# Options: mock | anthropic | openai | deepseek
LLM_PROVIDER=mock

# Model id per provider (only the selected provider's value is used).
# Default is the most capable Claude model; switch to claude-haiku-4-5 or a
# cheaper provider (deepseek) to cut investigator cost on high case volume.
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_MODEL=deepseek-chat

# API keys — only the selected provider's key is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# OpenAI-compatible base URLs (DeepSeek reuses the OpenAI SDK with a different base).
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
